{
  "Ollama": {
    "Endpoint": "http://localhost:11434",
    "DefaultModel": "qwen3:latest",
    "TimeoutSeconds": 300,
    "MaxRetries": 3,
    "RetryDelaySeconds": 2,
    "AgentModels": {
      "DefaultModel": "qwen3:latest",
      "SceneParser": "qwen3:latest",
      "SceneVerifier": "qwen3:latest",
      "PhotoPromptCreator": "qwen3:latest",
      "PhotoPromptVerifier": "qwen3:latest",
      "VideoPromptCreator": "qwen3:latest",
      "VideoPromptVerifier": "qwen3:latest"
    }
  },
  "ComfyUI": {
    "Endpoint": "http://127.0.0.1:8188",
    "TimeoutSeconds": 300,
    "PollIntervalMs": 5000,
     "WorkflowPath": "ComfyUiWorkflows/ComfyUI_SDXL_Image_Generation.json"
  },
  "Pipeline": {
    "MaxRetriesPerStage": 2,
    "UseBestAttemptOnFailure": true,
    "MaxRetriesPerAgent": {
      "SceneParsing": 2,
      "SceneVerification": 2,
      "PhotoPromptCreation": 2,
      "PhotoPromptVerification": 2,
      "VideoPromptCreation": 2,
      "VideoPromptVerification": 2,
      "ImageGeneration": 1
    },
    "UseBestAttemptOnFailurePerAgent": {
      "SceneVerification": true,
      "PhotoPromptVerification": true,
      "VideoPromptVerification": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  }
}
